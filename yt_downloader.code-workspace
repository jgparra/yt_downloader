{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		"files.exclude": {
			"**/.git": true,
			"**/__pycache__": true,
			"**/*.pyc": true
		},
		"files.associations": {
			"*.ps1": "powershell",
			"*.cmd": "bat"
		},
		"powershell.codeFormatting.preset": "OTBS",
		"editor.formatOnSave": false,
		"files.eol": "\n"
	},
	"extensions": {
		"recommendations": [
			"ms-vscode.powershell"
		]
	}
}
